{
  "name": "retn0claw",
  "version": "1.2.53",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "finalize-runner-sessions-cutover": "tsx scripts/finalize-runner-sessions-cutover.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "format": "prettier --write \"{src,tests,scripts}/**/*.ts\"",
    "format:fix": "prettier --write \"{src,tests,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests,scripts}/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "test:integration": "vitest run --project integration",
    "test:property:pr": "PROPERTY_RUNS=50 vitest run --project property",
    "test:property:stress": "PROPERTY_RUNS=200 vitest run --project property",
    "test:ci": "npm run test:unit && npm run test:contract && npm run test:integration && npm run test:property:pr"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "discord.js": "^14.18.0",
    "grammy": "^1.39.3",
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "fast-check": "^4.7.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
